<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.requirement.mapper.ReqIndexModuleMapper">
    <resultMap id="ReqIndexModuleResult" type="ReqIndexModule">
        <id property="indexModuleId" column="index_module_id"/>
        <result property="batchId" column="batch_id"/>
        <result property="projectId" column="project_id"/>
        <result property="repoId" column="repo_id"/>
        <result property="variantId" column="variant_id"/>
        <result property="parentCode" column="parent_code"/>
        <result property="moduleCode" column="module_code"/>
        <result property="moduleName" column="module_name"/>
        <result property="moduleType" column="module_type"/>
        <result property="repoScope" column="repo_scope"/>
        <result property="relativePath" column="relative_path"/>
        <result property="sourceRef" column="source_ref"/>
        <result property="summary" column="summary"/>
        <result property="orderNum" column="order_num"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectReqIndexModuleVo">
        select index_module_id, batch_id, project_id, repo_id, variant_id, parent_code, module_code, module_name,
               module_type, repo_scope, relative_path, source_ref, summary, order_num, status, create_by,
               create_time, update_by, update_time, remark
        from req_index_module
    </sql>

    <select id="checkReqIndexModuleTable" resultType="int">
        select count(1) from req_index_module where 1 = 0
    </select>

    <select id="selectReqIndexModuleList" parameterType="ReqIndexModule" resultMap="ReqIndexModuleResult">
        <include refid="selectReqIndexModuleVo"/>
        <where>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="repoId != null">and repo_id = #{repoId}</if>
            <if test="variantId != null">and variant_id = #{variantId}</if>
            <if test="moduleCode != null and moduleCode != ''">and module_code = #{moduleCode}</if>
            <if test="moduleName != null and moduleName != ''">and module_name like concat('%', #{moduleName}, '%')</if>
            <if test="moduleType != null and moduleType != ''">and module_type = #{moduleType}</if>
            <if test="repoScope != null and repoScope != ''">and repo_scope = #{repoScope}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            and batch_id in (
                select latest_batch_id from (
                    select max(batch_id) as latest_batch_id
                    from req_repository_index_batch
                    where status = 'imported'
                    <if test="projectId != null">and project_id = #{projectId}</if>
                    <if test="repoId != null">and repo_id = #{repoId}</if>
                    group by repo_id, branch_name
                ) latest_batches
            )
        </where>
        order by order_num asc, index_module_id asc
    </select>

    <select id="selectReqIndexModuleByIndexModuleId" parameterType="Long" resultMap="ReqIndexModuleResult">
        <include refid="selectReqIndexModuleVo"/>
        where index_module_id = #{indexModuleId}
    </select>

    <insert id="insertReqIndexModule" parameterType="ReqIndexModule" useGeneratedKeys="true" keyProperty="indexModuleId">
        insert into req_index_module
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="batchId != null">batch_id,</if>
            <if test="projectId != null">project_id,</if>
            <if test="repoId != null">repo_id,</if>
            <if test="variantId != null">variant_id,</if>
            <if test="parentCode != null and parentCode != ''">parent_code,</if>
            <if test="moduleCode != null and moduleCode != ''">module_code,</if>
            <if test="moduleName != null and moduleName != ''">module_name,</if>
            <if test="moduleType != null and moduleType != ''">module_type,</if>
            <if test="repoScope != null and repoScope != ''">repo_scope,</if>
            <if test="relativePath != null and relativePath != ''">relative_path,</if>
            <if test="sourceRef != null and sourceRef != ''">source_ref,</if>
            <if test="summary != null and summary != ''">summary,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="batchId != null">#{batchId},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="repoId != null">#{repoId},</if>
            <if test="variantId != null">#{variantId},</if>
            <if test="parentCode != null and parentCode != ''">#{parentCode},</if>
            <if test="moduleCode != null and moduleCode != ''">#{moduleCode},</if>
            <if test="moduleName != null and moduleName != ''">#{moduleName},</if>
            <if test="moduleType != null and moduleType != ''">#{moduleType},</if>
            <if test="repoScope != null and repoScope != ''">#{repoScope},</if>
            <if test="relativePath != null and relativePath != ''">#{relativePath},</if>
            <if test="sourceRef != null and sourceRef != ''">#{sourceRef},</if>
            <if test="summary != null and summary != ''">#{summary},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="deactivateReqIndexModulesByRepositoryBranch" parameterType="ReqIndexModule">
        update req_index_module
        set status = '1',
            update_by = #{updateBy},
            update_time = sysdate()
        where project_id = #{projectId}
          and repo_id = #{repoId}
        <choose>
            <when test="variantId != null">and variant_id = #{variantId}</when>
            <otherwise>and variant_id is null</otherwise>
        </choose>
          and status = '0'
    </update>
</mapper>
