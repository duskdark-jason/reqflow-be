<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.requirement.mapper.ReqProjectMapper">
    <resultMap id="ReqProjectResult" type="ReqProject">
        <id property="projectId" column="project_id"/>
        <result property="projectName" column="project_name"/>
        <result property="projectCode" column="project_code"/>
        <result property="description" column="description"/>
        <result property="ownerUserId" column="owner_user_id"/>
        <result property="workspaceAgentsTemplateVersion" column="workspace_agents_template_version"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectReqProjectVo">
        select project_id, project_name, project_code, description, owner_user_id, workspace_agents_template_version, status, create_by, create_time, update_by, update_time, remark
        from req_project
    </sql>

    <select id="selectReqProjectList" parameterType="ReqProject" resultMap="ReqProjectResult">
        <include refid="selectReqProjectVo"/>
        <where>
            <if test="projectName != null and projectName != ''">and project_name like concat('%', #{projectName}, '%')</if>
            <if test="projectCode != null and projectCode != ''">and project_code = #{projectCode}</if>
            <if test="ownerUserId != null">and owner_user_id = #{ownerUserId}</if>
            <if test="workspaceAgentsTemplateVersion != null and workspaceAgentsTemplateVersion != ''">and workspace_agents_template_version = #{workspaceAgentsTemplateVersion}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by project_id desc
    </select>

    <select id="selectReqProjectByProjectId" parameterType="Long" resultMap="ReqProjectResult">
        <include refid="selectReqProjectVo"/>
        where project_id = #{projectId}
    </select>

    <insert id="insertReqProject" parameterType="ReqProject" useGeneratedKeys="true" keyProperty="projectId">
        insert into req_project
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectName != null and projectName != ''">project_name,</if>
            <if test="projectCode != null and projectCode != ''">project_code,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="ownerUserId != null">owner_user_id,</if>
            <if test="workspaceAgentsTemplateVersion != null and workspaceAgentsTemplateVersion != ''">workspace_agents_template_version,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectName != null and projectName != ''">#{projectName},</if>
            <if test="projectCode != null and projectCode != ''">#{projectCode},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="ownerUserId != null">#{ownerUserId},</if>
            <if test="workspaceAgentsTemplateVersion != null and workspaceAgentsTemplateVersion != ''">#{workspaceAgentsTemplateVersion},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateReqProject" parameterType="ReqProject">
        update req_project
        <set>
            <if test="projectName != null and projectName != ''">project_name = #{projectName},</if>
            <if test="description != null and description != ''">description = #{description},</if>
            <if test="ownerUserId != null">owner_user_id = #{ownerUserId},</if>
            <if test="workspaceAgentsTemplateVersion != null and workspaceAgentsTemplateVersion != ''">workspace_agents_template_version = #{workspaceAgentsTemplateVersion},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where project_id = #{projectId}
    </update>

    <delete id="deleteReqProjectByProjectId" parameterType="Long">
        delete from req_project where project_id = #{projectId}
    </delete>

    <delete id="deleteReqProjectByProjectIds" parameterType="Long">
        delete from req_project where project_id in
        <foreach item="projectId" collection="array" open="(" separator="," close=")">
            #{projectId}
        </foreach>
    </delete>
</mapper>
