<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.requirement.mapper.ReqModuleMapper">
    <resultMap id="ReqModuleResult" type="ReqModule">
        <id property="moduleId" column="module_id"/>
        <result property="projectId" column="project_id"/>
        <result property="variantId" column="variant_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="moduleName" column="module_name"/>
        <result property="moduleCode" column="module_code"/>
        <result property="moduleType" column="module_type"/>
        <result property="repoScope" column="repo_scope"/>
        <result property="description" column="description"/>
        <result property="orderNum" column="order_num"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectReqModuleVo">
        select module_id, project_id, variant_id, parent_id, module_name, module_code, module_type, repo_scope, description, order_num, status, create_by, create_time, update_by, update_time, remark
        from req_module
    </sql>

    <select id="selectReqModuleList" parameterType="ReqModule" resultMap="ReqModuleResult">
        <include refid="selectReqModuleVo"/>
        <where>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="variantId != null">and variant_id = #{variantId}</if>
            <if test="parentId != null">and parent_id = #{parentId}</if>
            <if test="moduleName != null and moduleName != ''">and module_name like concat('%', #{moduleName}, '%')</if>
            <if test="moduleCode != null and moduleCode != ''">and module_code = #{moduleCode}</if>
            <if test="moduleType != null and moduleType != ''">and module_type = #{moduleType}</if>
            <if test="repoScope != null and repoScope != ''">and repo_scope = #{repoScope}</if>
            <if test="orderNum != null">and order_num = #{orderNum}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by order_num asc, module_id asc
    </select>

    <select id="selectReqModuleByModuleId" parameterType="Long" resultMap="ReqModuleResult">
        <include refid="selectReqModuleVo"/>
        where module_id = #{moduleId}
    </select>

    <insert id="insertReqModule" parameterType="ReqModule" useGeneratedKeys="true" keyProperty="moduleId">
        insert into req_module
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectId != null">project_id,</if>
            <if test="variantId != null">variant_id,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="moduleName != null and moduleName != ''">module_name,</if>
            <if test="moduleCode != null and moduleCode != ''">module_code,</if>
            <if test="moduleType != null and moduleType != ''">module_type,</if>
            <if test="repoScope != null and repoScope != ''">repo_scope,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectId != null">#{projectId},</if>
            <if test="variantId != null">#{variantId},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="moduleName != null and moduleName != ''">#{moduleName},</if>
            <if test="moduleCode != null and moduleCode != ''">#{moduleCode},</if>
            <if test="moduleType != null and moduleType != ''">#{moduleType},</if>
            <if test="repoScope != null and repoScope != ''">#{repoScope},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateReqModule" parameterType="ReqModule">
        update req_module
        <set>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="variantId != null">variant_id = #{variantId},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="moduleName != null and moduleName != ''">module_name = #{moduleName},</if>
            <if test="moduleType != null and moduleType != ''">module_type = #{moduleType},</if>
            <if test="repoScope != null and repoScope != ''">repo_scope = #{repoScope},</if>
            <if test="description != null and description != ''">description = #{description},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where module_id = #{moduleId}
    </update>

    <delete id="deleteReqModuleByModuleId" parameterType="Long">
        delete from req_module where module_id = #{moduleId}
    </delete>

    <delete id="deleteReqModuleByModuleIds" parameterType="Long">
        delete from req_module where module_id in
        <foreach item="moduleId" collection="array" open="(" separator="," close=")">
            #{moduleId}
        </foreach>
    </delete>
</mapper>
