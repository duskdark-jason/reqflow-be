<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.requirement.mapper.ReqMcpUserKeyMapper">
    <resultMap id="ReqMcpUserKeyResult" type="ReqMcpUserKey">
        <id property="keyId" column="key_id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="nickName" column="nick_name"/>
        <result property="keyName" column="key_name"/>
        <result property="keyPrefix" column="key_prefix"/>
        <result property="keyHash" column="key_hash"/>
        <result property="status" column="status"/>
        <result property="lastUsedTime" column="last_used_time"/>
        <result property="lastUsedIp" column="last_used_ip"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectReqMcpUserKeyVo">
        select k.key_id,
               k.user_id,
               u.user_name,
               u.nick_name,
               k.key_name,
               k.key_prefix,
               k.key_hash,
               k.status,
               k.last_used_time,
               k.last_used_ip,
               k.create_by,
               k.create_time,
               k.update_by,
               k.update_time,
               k.remark
        from req_mcp_user_key k
        left join sys_user u on u.user_id = k.user_id
    </sql>

    <select id="selectReqMcpUserKeyList" parameterType="ReqMcpUserKey" resultMap="ReqMcpUserKeyResult">
        <include refid="selectReqMcpUserKeyVo"/>
        <where>
            <if test="userId != null">and k.user_id = #{userId}</if>
            <if test="userName != null and userName != ''">and u.user_name like concat('%', #{userName}, '%')</if>
            <if test="nickName != null and nickName != ''">and u.nick_name like concat('%', #{nickName}, '%')</if>
            <if test="keyName != null and keyName != ''">and k.key_name like concat('%', #{keyName}, '%')</if>
            <if test="status != null and status != ''">and k.status = #{status}</if>
        </where>
        order by k.create_time desc, k.key_id desc
    </select>

    <select id="selectReqMcpUserKeyByKeyId" parameterType="Long" resultMap="ReqMcpUserKeyResult">
        <include refid="selectReqMcpUserKeyVo"/>
        where k.key_id = #{keyId}
    </select>

    <select id="selectReqMcpUserKeyByKeyHash" parameterType="String" resultMap="ReqMcpUserKeyResult">
        <include refid="selectReqMcpUserKeyVo"/>
        where k.key_hash = #{keyHash}
    </select>

    <insert id="insertReqMcpUserKey" parameterType="ReqMcpUserKey" useGeneratedKeys="true" keyProperty="keyId">
        insert into req_mcp_user_key
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="keyName != null and keyName != ''">key_name,</if>
            <if test="keyPrefix != null and keyPrefix != ''">key_prefix,</if>
            <if test="keyHash != null and keyHash != ''">key_hash,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="keyName != null and keyName != ''">#{keyName},</if>
            <if test="keyPrefix != null and keyPrefix != ''">#{keyPrefix},</if>
            <if test="keyHash != null and keyHash != ''">#{keyHash},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateReqMcpUserKey" parameterType="ReqMcpUserKey">
        update req_mcp_user_key
        <set>
            <if test="keyName != null and keyName != ''">key_name = #{keyName},</if>
            <if test="keyPrefix != null and keyPrefix != ''">key_prefix = #{keyPrefix},</if>
            <if test="keyHash != null and keyHash != ''">key_hash = #{keyHash},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="lastUsedTime != null">last_used_time = #{lastUsedTime},</if>
            <if test="lastUsedIp != null and lastUsedIp != ''">last_used_ip = #{lastUsedIp},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where key_id = #{keyId}
    </update>

    <delete id="deleteReqMcpUserKeyByKeyId" parameterType="Long">
        delete from req_mcp_user_key where key_id = #{keyId}
    </delete>

    <delete id="deleteReqMcpUserKeyByKeyIds" parameterType="Long">
        delete from req_mcp_user_key where key_id in
        <foreach item="keyId" collection="array" open="(" separator="," close=")">
            #{keyId}
        </foreach>
    </delete>

    <update id="updateLastUsed">
        update req_mcp_user_key
        set last_used_time = sysdate(),
            last_used_ip = #{lastUsedIp}
        where key_id = #{keyId}
    </update>
</mapper>
