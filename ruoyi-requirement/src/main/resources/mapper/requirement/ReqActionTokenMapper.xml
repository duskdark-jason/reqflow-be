<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.requirement.mapper.ReqActionTokenMapper">
    <resultMap id="ReqActionTokenResult" type="ReqActionToken">
        <id property="tokenId" column="token_id"/>
        <result property="actionType" column="action_type"/>
        <result property="tokenPrefix" column="token_prefix"/>
        <result property="tokenHash" column="token_hash"/>
        <result property="targetMethod" column="target_method"/>
        <result property="projectId" column="project_id"/>
        <result property="variantId" column="variant_id"/>
        <result property="demandId" column="demand_id"/>
        <result property="status" column="status"/>
        <result property="expireTime" column="expire_time"/>
        <result property="lastUsedTime" column="last_used_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectReqActionTokenVo">
        select token_id,
               action_type,
               token_prefix,
               token_hash,
               target_method,
               project_id,
               variant_id,
               demand_id,
               status,
               expire_time,
               last_used_time,
               create_by,
               create_time,
               update_by,
               update_time,
               remark
        from req_action_token
    </sql>

    <select id="selectReqActionTokenByTokenId" parameterType="Long" resultMap="ReqActionTokenResult">
        <include refid="selectReqActionTokenVo"/>
        where token_id = #{tokenId}
    </select>

    <select id="selectReqActionTokenByTokenHash" parameterType="String" resultMap="ReqActionTokenResult">
        <include refid="selectReqActionTokenVo"/>
        where token_hash = #{tokenHash}
    </select>

    <insert id="insertReqActionToken" parameterType="ReqActionToken" useGeneratedKeys="true" keyProperty="tokenId">
        insert into req_action_token
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="actionType != null and actionType != ''">action_type,</if>
            <if test="tokenPrefix != null and tokenPrefix != ''">token_prefix,</if>
            <if test="tokenHash != null and tokenHash != ''">token_hash,</if>
            <if test="targetMethod != null and targetMethod != ''">target_method,</if>
            <if test="projectId != null">project_id,</if>
            <if test="variantId != null">variant_id,</if>
            <if test="demandId != null">demand_id,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="actionType != null and actionType != ''">#{actionType},</if>
            <if test="tokenPrefix != null and tokenPrefix != ''">#{tokenPrefix},</if>
            <if test="tokenHash != null and tokenHash != ''">#{tokenHash},</if>
            <if test="targetMethod != null and targetMethod != ''">#{targetMethod},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="variantId != null">#{variantId},</if>
            <if test="demandId != null">#{demandId},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateReqActionToken" parameterType="ReqActionToken">
        update req_action_token
        <set>
            <if test="actionType != null and actionType != ''">action_type = #{actionType},</if>
            <if test="targetMethod != null and targetMethod != ''">target_method = #{targetMethod},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="lastUsedTime != null">last_used_time = #{lastUsedTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where token_id = #{tokenId}
    </update>

    <update id="updateLastUsed">
        update req_action_token
        set last_used_time = sysdate()
        where token_id = #{tokenId}
          and last_used_time is null
    </update>

    <update id="touchLastUsed">
        update req_action_token
        set last_used_time = sysdate()
        where token_id = #{tokenId}
    </update>

    <select id="countUsedActionToken" resultType="int">
        select count(1)
        from req_action_token
        where action_type = #{actionType}
          and target_method = #{targetMethod}
          and project_id = #{projectId}
          and variant_id = #{variantId}
          and demand_id = #{demandId}
          and status = '0'
          and last_used_time is not null
    </select>

    <delete id="deleteReqActionTokenByDemandIds" parameterType="Long">
        delete from req_action_token where demand_id in
        <foreach item="demandId" collection="array" open="(" separator="," close=")">
            #{demandId}
        </foreach>
    </delete>
</mapper>
